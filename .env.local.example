# Supabase (Pflichtfelder – siehe Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Server-seitiger Schlüssel – NIEMALS mit NEXT_PUBLIC_ prefix!
# Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# QR-Code JWT Signing Secret (min. 32 zufällige Zeichen)
# Generieren: openssl rand -base64 32
QR_TOKEN_SECRET=REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS

# App-URL (für QR-Code Aktivierungslinks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
